{
  "name": "sortudo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "fetch:json": "bun scripts/latest_sync_data.ts",
    "dev": "bun run fetch:json && vite",
    "build": "bun run fetch:json && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "knip": "knip",
    "prettier": "prettier --write .",
    "prepare": "husky",
    "tree": "tree -I \"node_modules|dist|.git|.vite|.agent|.devcontainer|.firebase|.github|.husky|.vscode\" > tree_output.txt"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "4.3.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.0.5",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "3.4.17",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "5.4.11",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "overrides": {
    "minimatch": "^9.0.6",
    "glob": "^10.5.0",
    "flatted": "^3.4.0"
  }
}
