{
  "name": "sortudo",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "process_excel": "bun scripts/elt_xlsx_to_json.ts",
    "dev": "bun run process_excel && vite",
    "build:dev": "bun run process_excel && vite build --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "codebase:devkit": "husky prepare && lint-staged",
    "codebase:smells": "bun run lint && bun run typecheck && bun run prettier && bun run knip",
    "codebase:tests": "bun run test:unit && bun run test:e2e",
    "codebase:tree": "find . -path './node_modules' -prune -o -path './dist' -prune -o -path './.git' -prune -o -path './.vite' -prune -o -path './.agent' -prune -o -path './.devcontainer' -prune -o -path './.firebase' -prune -o -path './.github' -prune -o -path './.husky' -prune -o -path './.vscode' -prune -o -print > tree_output.txt"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "@types/canvas-confetti": "1.9.0",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.38.0",
    "idb-keyval": "6.2.2",
    "lucide-react": "1.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "7.13.2",
    "recharts": "3.8.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "autoprefixer": "10.4.20",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "knip": "6.0.5",
    "lint-staged": "16.4.0",
    "playwright": "1.58.2",
    "postcss": "8.4.49",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  }
}
